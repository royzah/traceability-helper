#!/usr/bin/env bash
# Validate that the commit references an issue key. Placement-agnostic: works
# with the suffix, prefix, or footer style. Safety net for prepare-commit-msg.
set -euo pipefail

MSG_FILE="$1"
KEY_RE="$(git config --get traceability.keyPattern || echo '[A-Z][A-Z0-9]{1,9}-[0-9]+')"

CONTENT="$(grep -vE '^[[:space:]]*#' "$MSG_FILE" || true)"

if ! grep -qE "$KEY_RE" <<<"$CONTENT"; then
	{
		echo "ERROR: commit message must reference an issue key (e.g. SECO-1234)."
		echo "       Name the branch with the key to auto-inject it, or add it yourself."
		echo "       Default style stays Conventional-Commits valid:"
		echo "         feat: short summary (SECO-1234)"
	} >&2
	exit 1
fi

SUBJECT="$(grep -vE '^[[:space:]]*(#|$)' "$MSG_FILE" | head -n1)"
if [[ ${#SUBJECT} -gt 100 ]]; then
	echo "WARNING: subject is ${#SUBJECT} chars (recommended < 100)" >&2
fi
exit 0
