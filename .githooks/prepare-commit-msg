#!/usr/bin/env bash
# Inject the issue key from the branch name into the commit message.
#
# Default placement is a "(KEY)" suffix on the subject, which keeps
# Conventional Commits subjects valid. Override per repo:
#   git config traceability.keyPlacement suffix|prefix|footer
#   git config traceability.keyPattern '<regex>'   # default below
set -euo pipefail

MSG_FILE="$1"
COMMIT_SOURCE="${2:-}"

case "$COMMIT_SOURCE" in
merge | squash) exit 0 ;;
esac

BRANCH="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
[[ -n "$BRANCH" ]] || exit 0

KEY_RE="$(git config --get traceability.keyPattern || echo '[A-Z][A-Z0-9]{1,9}-[0-9]+')"
[[ "$BRANCH" =~ ($KEY_RE) ]] || exit 0
KEY="${BASH_REMATCH[1]}"

# Already referenced anywhere in the message: leave it untouched.
if grep -qE "$KEY" "$MSG_FILE"; then
	exit 0
fi

PLACEMENT="$(git config --get traceability.keyPlacement || echo suffix)"

if [[ "$PLACEMENT" == "footer" ]]; then
	git interpret-trailers --trailer "Refs: ${KEY}" --in-place "$MSG_FILE"
	exit 0
fi

# Subject is the first non-empty, non-comment line.
SUBJECT_LINE="$(grep -nvE '^[[:space:]]*(#|$)' "$MSG_FILE" | head -n1 | cut -d: -f1 || true)"
[[ -n "$SUBJECT_LINE" ]] || exit 0

TMP="$(mktemp)"
if [[ "$PLACEMENT" == "prefix" ]]; then
	awk -v n="$SUBJECT_LINE" -v k="$KEY" 'NR==n{$0="["k"] "$0} {print}' "$MSG_FILE" >"$TMP"
else
	awk -v n="$SUBJECT_LINE" -v k="$KEY" 'NR==n{$0=$0" ("k")"} {print}' "$MSG_FILE" >"$TMP"
fi
mv "$TMP" "$MSG_FILE"
